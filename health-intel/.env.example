# Core app
APP_ENV=production
APP_VERSION=1.0.0
ENABLE_DOCS=false
ENABLE_SCHEDULER=false
ENABLE_DEMO_TOOLS=false
ALLOW_SQLITE_IN_PRODUCTION=false
RUN_STARTUP_SCHEMA_PATCHES=false
RATE_LIMIT_PER_MINUTE=120
API_PORT=8000
UVICORN_WORKERS=1
ALLOWED_HOSTS=api.yourdomain.com,localhost,127.0.0.1
CORS_ALLOW_ORIGINS=https://app.yourdomain.com
CORS_ALLOW_ORIGIN_REGEX=
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Firebase web push config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_VAPID_KEY=REPLACE_WITH_WEB_PUSH_VAPID_PUBLIC_KEY

# Database (choose either DATABASE_URL or DB_* vars)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/pcube_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pcube_db
POSTGRES_PORT=5432
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_DRIVER=postgresql+psycopg2

# Security/Auth
JWT_SECRET=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAILS=dianice1918@gmail.com
CHAT_IMAGE_MAX_BYTES=5242880
LOGIN_OTP_ENABLED=true
LOGIN_OTP_TTL_MINUTES=10
LOGIN_OTP_DIGITS=6
LOGIN_OTP_MAX_ATTEMPTS=5
LOGIN_OTP_MAX_ISSUES_PER_10_MIN=6
LOGIN_OTP_SECRET=

# LLM
LLM_PROVIDER=openai
LLM_REQUEST_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_MAX_TOKENS=500
OPENAI_API_BASE=https://api.openai.com/v1/chat/completions
OLLAMA_API_BASE=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3.1:8b
XAI_API_KEY=
XAI_CHAT_MODEL=grok-4
XAI_API_BASE=https://api.x.ai/v1/chat/completions

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_HOST=
PINECONE_ASSISTANT_NAME=
PINECONE_CHAT_MODEL=gpt-4o
PINECONE_API_BASE=https://prod-1-data.ke.pinecone.io/assistant/chat/{assistant_name}/chat/completions
PINECONE_FILES_API_BASE=https://prod-1-data.ke.pinecone.io/assistant/files/{assistant_name}
PINECONE_API_VERSION=2025-10
PINECONE_FILE_MAX_BYTES=20971520

# Weather/Intel
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
OPENWEATHER_API_KEY=
IQAIR_API_KEY=
NEWSAPI_KEY=
NCDC_ALERT_URL=https://ncdc.gov.ng/news
LIVE_INTEL_CACHE_SECONDS=900
LIVE_INTEL_INTERVAL_MINUTES=60
ENABLE_LIVE_INTEL_JOB=true
LIVE_INTEL_ALERT_COOLDOWN_MINUTES=180
RISK_CHECK_INTERVAL_HOURS=24
OUTBREAK_BULLETINS=

# Email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS / WhatsApp (Twilio)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
TWILIO_WHATSAPP_FROM=

# Push notifications (Firebase)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=REPLACE_WITH_FIREBASE_SERVICE_ACCOUNT_JSON
FCM_OAUTH_SCOPE=https://www.googleapis.com/auth/firebase.messaging
FCM_V1_ENDPOINT=

# Wearable OAuth
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
GOOGLE_FIT_REDIRECT_URI=https://api.yourdomain.com/integrations/wearables/google_fit/oauth/callback
GOOGLE_FIT_SCOPES=https://www.googleapis.com/auth/fitness.activity.read https://www.googleapis.com/auth/fitness.heart_rate.read
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=https://api.yourdomain.com/integrations/wearables/fitbit/oauth/callback
FITBIT_SCOPES=activity heartrate profile sleep
